# Copy this file to .env and fill in your own values.
# Never commit the .env file — it is listed in .gitignore.

# ---------------------------------------------------------
# Database (Neon / PostgreSQL)
# Get these from your Neon project dashboard or any Postgres provider.
# ---------------------------------------------------------
DATABASE_URL=postgresql://<user>:<password>@<host>/<database>?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://<user>:<password>@<host-unpooled>/<database>?sslmode=require

PGHOST=<pooled-host>
PGHOST_UNPOOLED=<unpooled-host>
PGUSER=<user>
PGDATABASE=<database>
PGPASSWORD=<password>

# Vercel Postgres / Neon template variables
POSTGRES_URL=postgresql://<user>:<password>@<host>/<database>?sslmode=require
POSTGRES_URL_NON_POOLING=postgresql://<user>:<password>@<host-unpooled>/<database>?sslmode=require
POSTGRES_USER=<user>
POSTGRES_HOST=<pooled-host>
POSTGRES_PASSWORD=<password>
POSTGRES_DATABASE=<database>
POSTGRES_URL_NO_SSL=postgresql://<user>:<password>@<host>/<database>
POSTGRES_PRISMA_URL=postgresql://<user>:<password>@<host>/<database>?connect_timeout=15&sslmode=require

# ---------------------------------------------------------
# Better Auth
# Generate a secret with: openssl rand -base64 32
# ---------------------------------------------------------
BETTER_AUTH_SECRET=<generate-with-openssl-rand-base64-32>
BETTER_AUTH_URL=http://localhost:3000
